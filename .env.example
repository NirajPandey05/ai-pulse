# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# SMTP credentials — works with Gmail, Outlook, Zoho, Yahoo, or any SMTP provider
SMTP_USER=your_sender_email@example.com
SMTP_PASSWORD=your_app_password_here

# SMTP server settings (defaults shown are for Gmail)
# Gmail:    smtp.gmail.com        port 465  tls=ssl
# Outlook:  smtp.office365.com    port 587  tls=starttls
# Zoho:     smtp.zoho.com         port 465  tls=ssl
# Yahoo:    smtp.mail.yahoo.com   port 465  tls=ssl
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_TLS=ssl

# Destination email
RECIPIENT_EMAIL=your_recipient_email@example.com
